# ===========================================================================
# ZeitVault – .gitignore (Monorepo: pnpm + Turborepo)
# ===========================================================================

# --- Abhängigkeiten ---------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log*

# --- Build-Ausgaben ---------------------------------------------------------
dist/
build/
out/
.next/
.expo/
.turbo/
*.tsbuildinfo
coverage/
.nyc_output/

# --- Caches -----------------------------------------------------------------
.cache/
.eslintcache
.swc/

# --- Umgebung & Secrets (NIE committen, siehe SECURITY.md) ------------------
.env
.env.*
!.env.example
*.local
*.pem
*.key
*.p12
*.pfx
secrets.*
!secrets.example.*

# --- IaC / Infrastruktur ----------------------------------------------------
# OpenTofu / Terraform State enthält ggf. sensible Daten -> nie committen
*.tfstate
*.tfstate.*
.terraform/
.tofu/
crash.log

# --- Logs -------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Test-/Tooling-Artefakte ------------------------------------------------
playwright-report/
test-results/
*.lcov

# --- Editor / OS ------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
.DS_Store
Thumbs.db

# --- Mobile (Expo/RN) -------------------------------------------------------
*.keystore
!debug.keystore
ios/Pods/
android/.gradle/

# --- Generierte Artefakte (werden im Build erzeugt, nicht versioniert) ------
# Hinweis: pnpm-lock.yaml WIRD committet (reproduzierbare Builds, siehe §5.1)
sbom.json
sbom.spdx.json
