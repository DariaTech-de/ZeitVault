# ZeitVault API - Beispielkonfiguration. Kopieren nach .env (nicht committen).
NODE_ENV=development
PORT=3000

# PostgreSQL 18 (siehe infra/docker/docker-compose.yml)
DATABASE_URL=postgres://zeitvault:zeitvault@localhost:5432/zeitvault

# Audit-Ledger-Service (getrennte Vertrauensgrenze, ADR-0006)
LEDGER_URL=http://localhost:3001

# Keycloak (OIDC) - Auth-Anbindung folgt; siehe ADR-0008
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/zeitvault
