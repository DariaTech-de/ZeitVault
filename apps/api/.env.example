# ZeitVault API - Beispielkonfiguration. Kopieren nach .env (nicht committen).
NODE_ENV=development
PORT=3000

# PostgreSQL 18 (siehe infra/docker/docker-compose.yml)
DATABASE_URL=postgres://zeitvault:zeitvault@localhost:5432/zeitvault

# Audit-Ledger-Service (getrennte Vertrauensgrenze, ADR-0006)
LEDGER_URL=http://localhost:3001

# Authentifizierung (ADR-0008):
#   oidc = produktionssicher (Bearer-Token gegen Keycloak-JWKS) - Default
#   dev  = nur lokal/Tests (Tenant/User aus Headern x-tenant-id/x-user-id/x-roles)
AUTH_MODE=oidc
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/zeitvault
# Optionale Audience-Pruefung und Tenant-Claim-Name
# KEYCLOAK_AUDIENCE=zeitvault-api
TENANT_CLAIM=tenant_id
DEFAULT_TENANT_ID=default
