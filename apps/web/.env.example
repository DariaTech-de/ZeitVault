# ZeitVault Web - Beispielkonfiguration. Kopieren nach .env.local (nicht committen).

# Basis-URL der API (apps/api).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Auth-Modus: 'oidc' (produktiv, Keycloak) oder 'dev' (lokal/Sandbox, Header).
NEXT_PUBLIC_AUTH_MODE=dev

# --- OIDC-Modus (Keycloak, Authorization Code + PKCE; ADR-0008) ---
NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:8080/realms/zeitvault
NEXT_PUBLIC_OIDC_CLIENT_ID=zeitvault-web
# Redirect-Ziel (muss als gueltige Redirect-URI im Keycloak-Client hinterlegt sein).
NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_OIDC_SCOPE=openid profile

# --- Dev-Modus (ohne Keycloak): Demo-Identitaet ---
# userId entspricht dem festen Subject des Keycloak-Demo-Nutzers, damit /me
# denselben Mitarbeiter wie nach echtem Login aufloest.
NEXT_PUBLIC_TENANT_ID=default
NEXT_PUBLIC_USER_ID=11111111-1111-1111-1111-111111111111
NEXT_PUBLIC_EMPLOYEE_ID=11111111-1111-1111-1111-111111111111
