# ZeitVault Web - Beispielkonfiguration. Kopieren nach .env.local (nicht committen).
# Basis-URL der API (apps/api).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Demo-Identitaet fuer das Scaffold (im Zielbild aus dem OIDC-Token, ADR-0008).
NEXT_PUBLIC_TENANT_ID=default
NEXT_PUBLIC_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_EMPLOYEE_ID=00000000-0000-0000-0000-000000000001
