{
  "name": "@zeitvault/ledger",
  "version": "0.0.0",
  "private": true,
  "description": "ZeitVault Audit-Ledger (append-only, hash-verkettet) - getrennte Vertrauensgrenze",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
