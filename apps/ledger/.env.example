# ZeitVault Audit-Ledger - Beispielkonfiguration. Kopieren nach .env (nicht committen).
NODE_ENV=development
PORT=3001

# Getrennte Datenbank/Schema fuer den Ledger (Vertrauensgrenze, ADR-0006).
# Der DB-User des Ledgers sollte nur INSERT/SELECT auf audit_events besitzen.
DATABASE_URL=postgres://zeitvault:zeitvault@localhost:5432/zeitvault_ledger
