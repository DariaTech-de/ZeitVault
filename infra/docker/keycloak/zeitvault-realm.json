{
  "realm": "zeitvault",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "employee", "description": "Mitarbeiter (Self-Service)" },
      { "name": "manager", "description": "Vorgesetzte/Genehmiger" },
      { "name": "admin", "description": "Administration" }
    ]
  },
  "clients": [
    {
      "clientId": "zeitvault-web",
      "name": "ZeitVault Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "default",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "email": "demo@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Nutzer",
      "credentials": [{ "type": "password", "value": "demo", "temporary": false }],
      "realmRoles": ["employee"]
    },
    {
      "username": "admin-demo",
      "enabled": true,
      "email": "admin-demo@example.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Demo",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["employee", "manager", "admin"]
    }
  ]
}
