# ZeitVault Produktion - Vorlage. Kopieren nach `.env` und Werte setzen:
#   cp .env.prod.example .env   (im Ordner infra/docker/)
# Die .env NIEMALS committen (steht in .gitignore).

# ---- Domains (oeffentliche DNS-A/AAAA-Records auf diesen Host) ----
APP_DOMAIN=zeitvault.example.com
AUTH_DOMAIN=auth.example.com
# E-Mail fuer Let's Encrypt (Zertifikatsablauf-Hinweise).
ACME_EMAIL=admin@example.com

# ---- Secrets (STARKE Zufallswerte einsetzen!) ----
# WICHTIG: POSTGRES_PASSWORD wird in DB-URLs verwendet und muss daher
# URL-sicher sein (nur 0-9 a-f). Erzeugen mit:  openssl rand -hex 24
# (KEIN `-base64`, da dessen Sonderzeichen / + = die URL zerstoeren.)
POSTGRES_PASSWORD=BITTE_AENDERN_hex_zufallspasswort
KEYCLOAK_ADMIN=admin
# Keycloak-Passwort ist kein URL-Bestandteil, hier ist jedes starke Passwort ok.
KEYCLOAK_ADMIN_PASSWORD=BITTE_AENDERN_langes_zufallspasswort

# ---- Optional ----
# Audience-Claim, gegen den die API das Token prueft (Keycloak-Standard: account).
KEYCLOAK_AUDIENCE=account
# Oeffentlicher Ed25519-Lizenzschluessel (PEM, Zeilenumbrueche als \n). Leer = Testmodus.
LICENSE_PUBLIC_KEY=
LICENSE_GRACE_SEATS=5
