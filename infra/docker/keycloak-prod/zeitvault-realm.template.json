{
  "realm": "zeitvault",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "employee",
        "description": "Mitarbeiter (Self-Service)"
      },
      {
        "name": "manager",
        "description": "Vorgesetzte/Genehmiger"
      },
      {
        "name": "admin",
        "description": "Administration"
      }
    ]
  },
  "clients": [
    {
      "clientId": "zeitvault-web",
      "name": "ZeitVault Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "https://${APP_DOMAIN}/*"
      ],
      "webOrigins": [
        "https://${APP_DOMAIN}"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://${APP_DOMAIN}/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "default",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "zeitvault-mobile",
      "name": "ZeitVault Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "zeitvault://*",
        "exp://*"
      ],
      "webOrigins": [
        "https://${APP_DOMAIN}"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "default",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "webAuthnPolicyPasswordlessRpEntityName": "ZeitVault",
  "webAuthnPolicyPasswordlessRpId": "",
  "webAuthnPolicyPasswordlessSignatureAlgorithms": [
    "ES256",
    "RS256"
  ],
  "webAuthnPolicyPasswordlessAttestationConveyancePreference": "not specified",
  "webAuthnPolicyPasswordlessAuthenticatorAttachment": "not specified",
  "webAuthnPolicyPasswordlessRequireResidentKey": "Yes",
  "webAuthnPolicyPasswordlessUserVerificationRequirement": "required",
  "webAuthnPolicyPasswordlessCreateTimeout": 0,
  "webAuthnPolicyPasswordlessAvoidSameAuthenticatorRegister": false,
  "webAuthnPolicyPasswordlessAcceptableAaguids": [],
  "requiredActions": [
    {
      "alias": "webauthn-register-passwordless",
      "name": "Webauthn Register Passwordless",
      "providerId": "webauthn-register-passwordless",
      "enabled": true,
      "defaultAction": false,
      "priority": 80,
      "config": {}
    }
  ],
  "authenticationFlows": [
    {
      "alias": "ZeitVault Browser mit Passkey",
      "description": "Browser-Login: Passkey (WebAuthn Passwordless) oder Passwort",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "authenticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "authenticator": "identity-provider-redirector",
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "authenticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "authenticatorFlow": true,
          "flowAlias": "ZeitVault Forms",
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "ZeitVault Forms",
      "description": "Benutzername, danach Passkey oder Passwort",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-form",
          "requirement": "REQUIRED",
          "priority": 10,
          "authenticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "requirement": "REQUIRED",
          "priority": 20,
          "authenticatorFlow": true,
          "flowAlias": "ZeitVault Auth",
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "ZeitVault Auth",
      "description": "Passkey (WebAuthn Passwordless) als Alternative zum Passwort",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "webauthn-authenticator-passwordless",
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "authenticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "authenticatorFlow": true,
          "flowAlias": "ZeitVault Passwort",
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "ZeitVault Passwort",
      "description": "Passwort-Formular",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-password-form",
          "requirement": "REQUIRED",
          "priority": 10,
          "authenticatorFlow": false,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "browserFlow": "ZeitVault Browser mit Passkey"
}
