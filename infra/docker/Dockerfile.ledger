# ZeitVault Audit-Ledger - Mehrstufiger Build. Build-Kontext ist das Repo-Root (../..).
# Basis-Image in Produktion per Digest pinnen (ADR-0003).
FROM node:24-bookworm-slim AS build
RUN corepack enable
WORKDIR /repo
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @zeitvault/ledger... build

FROM node:24-bookworm-slim AS runtime
ENV NODE_ENV=production
WORKDIR /repo
COPY --from=build /repo /repo
WORKDIR /repo/apps/ledger
EXPOSE 3001
USER node
CMD ["node", "dist/main.js"]
