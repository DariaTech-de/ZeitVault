# ZeitVault pnpm configuration
# Node 24 LTS ist Zielversion (siehe .node-version); lokale Builds duerfen aber
# auf aelteren LTS-Linien laufen, daher kein harter Engine-Abbruch.
engine-strict=false
auto-install-peers=true
# Reproduzierbare Builds: exakte Aufloesung im Lockfile (siehe ADR-0003).
save-exact=false
